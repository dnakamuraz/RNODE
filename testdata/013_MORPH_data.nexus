begin mrbayes;
	set autoclose = yes nowarn = yes;
	exclude 3 6 7 17 18 19 21 22 23 24 26 29 33 34 35 36 37 42 43 44 45 46 47 49 50 55 56 57 58 59 60 61 62 76 78 79 92 94 95 96 97 98 99 100 103 109 114 115 116 118 119 120 123 125 129 130 132 133;
	lset coding = informative rates = gamma;
	set usebeagle = yes beagledevice = CPU beagleprecision = double beaglescaling = always beaglesse = no;
	mcmcp temp = 0.1 nchain = 4 samplefreq = 500 printfr = 1000 nruns = 2 append = no;
	mcmcp filename = 003_mollusc_morph;
	mcmc ngen = 5000000;
sumt relburnin = yes burninfrac = 0.25;
sumt Contype = Allcompat relburnin = yes Outputname = 003_mollusc_morph.allcompat burninfrac = 0.25;
sump relburnin = yes burninfrac = 0.25;

END;
