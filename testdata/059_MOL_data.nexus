				getEmployee #mesquite.chromaseq.ColorQuality.ColorQuality;
				tell It;
					toggleAmbiguities on;
					toggleMarks on;
				endTell;
				getEmployee #mesquite.molec.SequenceInfoEditor.SequenceInfoEditor;
				tell It;
					panelOpen false;
				endTell;
				getEmployee #mesquite.chromaseq.SourceFileInfoEditor.SourceFileInfoEditor;
				tell It;
					panelOpen false;
				endTell;
			endTell;
		endTell;
		endTell;
end;


